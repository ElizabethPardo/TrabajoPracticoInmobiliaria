<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_inicio">

    <fragment
        android:id="@+id/nav_inicio"
        android:name="com.example.trabajopracticoinmobiliaria.ui.inicio.InicioFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_inicio" />

    <fragment
        android:id="@+id/nav_perfil"
        android:name="com.example.trabajopracticoinmobiliaria.ui.perfil.PerfilFragment"
        android:label="@string/menu_perfil"
        tools:layout="@layout/fragment_perfil" >
    <action
        android:id="@+id/action_nav_perfil_to_cambioPassFragment"
        app:destination="@id/cambioPassFragment" />
    </fragment>

    <fragment
        android:id="@+id/cambioPassFragment"
        android:name="com.example.trabajopracticoinmobiliaria.ui.perfil.CambioPassFragment"
        android:label="Cambio de contraseña"
        tools:layout="@layout/fragment_cambio_pass">
        <action
            android:id="@+id/action_cambioPassFragment_to_nav_perfil"
            app:destination="@id/nav_perfil" />
    </fragment>

    <fragment
        android:id="@+id/nav_inmueble"
        android:name="com.example.trabajopracticoinmobiliaria.ui.inmuebles.InmuebleFragment"
        android:label="Inmuebles"
        tools:layout="@layout/fragment_inmueble">
        <action
            android:id="@+id/action_nav_inmuebles_to_agregarInmuebleFragment"
            app:destination="@id/agregarInmuebleFragment" />
        <action
            android:id="@+id/action_nav_inmuebles_to_inmuebleDetalleFragment"
            app:destination="@id/inmuebleDetalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/agregarInmuebleFragment"
        android:name="com.example.trabajopracticoinmobiliaria.ui.inmuebles.AgregarInmuebleFragment"
        android:label="Inmueble"
        tools:layout="@layout/fragment_agregar_inmueble">
    </fragment>

    <fragment
        android:id="@+id/inmuebleDetalleFragment"
        android:name="com.example.trabajopracticoinmobiliaria.ui.inmuebles.InmuebleDetalleFragment"
        android:label="Inmueble"
        tools:layout="@layout/fragment_inmueble_detalle">
        <action
            android:id="@+id/action_inmuebleDetalleFragment_to_nav_inmuebles"
            app:destination="@id/nav_inmueble" />
    </fragment>

    <fragment
        android:id="@+id/nav_inquilino"
        android:name="com.example.trabajopracticoinmobiliaria.ui.inquilinos.InquilinoFragment"
        android:label="Inquilinos"
        tools:layout="@layout/fragment_inquilino" />

    <fragment
        android:id="@+id/nav_contrato"
        android:name="com.example.trabajopracticoinmobiliaria.ui.contratos.ContratoFragment"
        android:label="Contratos"
        tools:layout="@layout/fragment_contrato">
        <action
            android:id="@+id/action_nav_contrato_to_contratoDetalleFragment"
            app:destination="@id/contratoDetalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/contratoDetalleFragment"
        android:name="com.example.trabajopracticoinmobiliaria.ui.contratos.ContratoDetalleFragment"
        android:label="Contrato"
        tools:layout="@layout/fragment_contrato_detalle" >
        <action
            android:id="@+id/action_contratoDetalleFragment_to_nav_contrato"
            app:destination="@id/nav_contrato" />
        <action
            android:id="@+id/action_contratoDetalleFragment_to_pagoFragment"
            app:destination="@id/pagoFragment" />
    </fragment>

    <fragment
        android:id="@+id/pagoFragment"
        android:name="com.example.trabajopracticoinmobiliaria.ui.contratos.PagoFragment"
        android:label="Detalle de Pagos"
        tools:layout="@layout/fragment_pago" >
        <action
            android:id="@+id/action_pagoFragment_to_contratoDetalleFragment"
            app:destination="@id/contratoDetalleFragment" />
    </fragment>

    <fragment
        android:id="@+id/nav_salir"
        android:name="com.example.trabajopracticoinmobiliaria.ui.salir.SalirFragment"
        android:label="Salir"
        tools:layout="@layout/fragment_salir" />
</navigation>